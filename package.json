{
  "name": "tnt.collection",
  "version": "2.1.1",
  "devCounter": 69,
  "description": "TNT Collection Tools for Ikariam",
  "private": true,
  "author": "Ronny Jespersen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheNorthman/tnt.collection.git"
  },
  "homepage": "https://github.com/TheNorthman/tnt.collection",
  "bugs": {
    "url": "https://github.com/TheNorthman/tnt.collection/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "bash ./build.sh dev",
    "build:prod": "bash ./build.sh prod"
  },
  "keywords": [
    "userscript",
    "ikariam",
    "tnt.collection"
  ],

  "modules": {
    "core": {
      "order": 100,
      "dev": {
        "enabled": true,
        "js": ["core.js", "metadata.js"],
        "css": ["styles.css"]
      },
      "prod": {
        "enabled": true,
        "js": ["core.js", "metadata.js"],
        "css": ["styles.css"]
      }
    },

    "dataCollector": {
      "order": 200,
      "dev": {
        "enabled": true,
        "js": ["dataCollector.js"]
      },
      "prod": {
        "enabled": true,
        "js": ["dataCollector.js"]
      }
    },

    "citySwitcher": {
      "order": 300,
      "dev": {
        "enabled": true,
        "js": ["citySwitcher.js"]
      },
      "prod": {
        "enabled": true,
        "js": ["citySwitcher.js"]
      }
    },

    "tableBuilder": {
      "order": 400,
      "dev": {
        "enabled": true,
        "js": ["tableBuilder.js"]
      },
      "prod": {
        "enabled": true,
        "js": ["tableBuilder.js"]
      }
    },

    "tooltip": {
      "order": 500,
      "dev": {
        "enabled": true,
        "js": ["tooltip.js"]
      },
      "prod": {
        "enabled": true,
        "js": ["tooltip.js"]
      }
    },

    "debug": {
      "order": 900,
      "dev": {
        "enabled": true,
        "js": ["debug.js"],
        "css": ["debug.css"]
      },
      "prod": {
        "enabled": false,
        "js": ["debug.js"],
        "css": ["debug.css"]
      }
    }
  }
}
